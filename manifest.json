{
  "manifest_version": 3,
  "name": "对话标尺",
  "version": "1.3.0",
  "description": "Chat Ruler - 在AI对话页面右侧显示轮次导航侧边栏，支持快速跳转定位。适配Kimi、Gemini、DeepSeek、豆包、元宝、ChatGPT。",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://kimi.moonshot.cn/*",
        "https://*.kimi.moonshot.cn/*",
        "https://kimi.com/*",
        "https://*.kimi.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://*.deepseek.com/*",
        "https://doubao.com/*",
        "https://*.doubao.com/*",
        "https://www.doubao.com/*",
        "https://yuanbao.tencent.com/*",
        "https://*.yuanbao.tencent.com/*",
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://*.chat.openai.com/*"
      ],
      "run_at": "document_idle",
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}